@model academico.Models.Projeto

@{
    ViewData["Title"] = "Excluir Projeto";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="header-section mb-5 text-center">
                <div class="icon-box-danger mb-2">
                    <i class="bi bi-exclamation-octagon"></i>
                </div>
                <h1 class="fw-bold text-dark m-0">Excluir Projeto</h1>
                <p class="text-danger fw-bold">Tem certeza que deseja remover este registro?</p>
                <div class="title-underline-danger"></div>
            </div>

            <div class="form-container shadow-lg p-5 bg-white border-top border-danger border-5">

                <div class="form-group-custom">
                    <label class="inp readonly-field">
                        <input value="@Model.Nome" readonly />
                        <span class="label-text">Nome do Projeto</span>
                    </label>
                </div>

                <div class="row">
                    <div class="col-md-7">
                        <div class="form-group-custom">
                            <label class="inp readonly-field">
                                <input value="@Model.Sigla" class="text-uppercase" readonly />
                                <span class="label-text">Sigla</span>
                            </label>
                        </div>
                    </div>
                    <div class="col-md-5">
                        <div class="form-group-custom">
                            <label class="inp readonly-field">
                                <input value="@Model.Ano" readonly />
                                <span class="label-text">Ano</span>
                            </label>
                        </div>
                    </div>
                </div>

                <div class="form-group-custom">
                    <label class="inp readonly-field">
                        <input value="@Model.Status" readonly />
                        <span class="label-text">Status Atual</span>
                    </label>
                </div>

                <hr class="my-4">

                <form asp-action="Delete">
                    <input type="hidden" asp-for="ProjetoId" />

                    <div class="row g-2">
                        <div class="col-md-8">
                            <button type="submit" class="btn btn-danger btn-lg w-100 shadow-sm fw-bold">
                                <i class="bi bi-trash"></i> CONFIRMAR EXCLUSÃO
                            </button>
                        </div>
                        <div class="col-md-4">
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg w-100">
                                CANCELAR
                            </a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --danger: #DC3545;
        --dark: #1a1a1a;
        --bg-readonly: rgba(0, 0, 0, 0.01);
    }

    .icon-box-danger {
        font-size: 3rem;
        color: var(--danger);
    }

    .title-underline-danger {
        width: 40px;
        height: 4px;
        background: var(--danger);
        margin: 10px auto;
        border-radius: 10px;
    }

    .form-container {
        border-radius: 15px;
    }

    .form-group-custom {
        margin-bottom: 1.5rem;
        position: relative;
    }

    .inp {
        position: relative;
        width: 100%;
        display: block;
        background: var(--bg-readonly);
        border-radius: 4px;
        overflow: hidden;
    }

    .inp .label-text {
        position: absolute;
        top: 20px;
        left: 15px;
        font-size: 16px;
        color: rgba(0, 0, 0, 0.4);
        font-weight: 500;
        transform: translate3d(0, -15px, 0) scale(.75);
        pointer-events: none;
        z-index: 3;
    }

    .inp input {
        width: 100%;
        border: 0;
        padding: 26px 15px 10px 15px;
        height: 65px;
        font-size: 16px;
        background: transparent;
        box-shadow: inset 0 -1px 0 rgba(0, 0, 0, 0.1);
        color: #666;
        cursor: not-allowed;
    }

    .inp input:focus {
        outline: none;
    }

    .text-uppercase {
        text-transform: uppercase;
    }

    .btn-danger {
        background-color: var(--danger);
        border: none;
        transition: all 0.3s;
    }

    .btn-danger:hover {
        background-color: #a71d2a;
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(220, 53, 69, 0.3);
    }
</style>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">