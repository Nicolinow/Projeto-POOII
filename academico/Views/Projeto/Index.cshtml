@model IEnumerable<academico.Models.Projeto>

@{
    ViewData["Title"] = "Projetos Acadêmicos";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold text-dark m-0">Projetos</h1>
            <p class="text-muted">Gerencie os registros cadastrados no sistema</p>
        </div>
        <a asp-action="Create" class="btn btn-primary shadow-sm px-4">
            <i class="bi bi-plus-lg"></i> Novo Projeto
        </a>
    </div>

    <div class="card shadow-sm border-0 rounded-3">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">@Html.DisplayNameFor(model => model.Nome)</th>
                        <th>@Html.DisplayNameFor(model => model.Sigla)</th>
                        <th class="text-center">@Html.DisplayNameFor(model => model.Ano)</th>
                        <th class="text-center">@Html.DisplayNameFor(model => model.Status)</th>
                        <th class="text-end pe-4">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-semibold text-dark">
                                @Html.DisplayFor(modelItem => item.Nome)
                            </td>
                            <td>
                                <span class="badge bg-secondary-subtle text-secondary border">@item.Sigla</span>
                            </td>
                            <td class="text-center">
                                @Html.DisplayFor(modelItem => item.Ano)
                            </td>
                            <td class="text-center">
                                @{
                                    var statusClass = item.Status.ToString() switch
                                    {
                                        "Implantado" => "bg-success",
                                        "EmDesenvolvimento" => "bg-primary",
                                        "EmDefesa" => "bg-warning text-dark",
                                        _ => "bg-info"
                                    };
                                }
                                <span class="badge @statusClass">
                                    @Html.DisplayFor(modelItem => item.Status)
                                </span>
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group btn-group-sm" role="group">
                                    <a asp-action="Edit" asp-route-id="@item.ProjetoId" class="btn btn-outline-primary" title="Editar">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.ProjetoId" class="btn btn-outline-info" title="Detalhes">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.ProjetoId" class="btn btn-outline-danger" title="Excluir">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .table thead th {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-weight: 700;
        padding: 15px 10px;
        border-bottom: 2px solid #f0f0f0;
    }

    .table tbody td {
        padding: 15px 10px;
        border-bottom: 1px solid #f8f9fa;
    }

    .table-hover tbody tr:hover {
        background-color: rgba(0, 119, 255, 0.02);
        transition: background-color 0.2s ease;
    }

    .badge {
        padding: 0.5em 0.8em;
        font-weight: 600;
        border-radius: 6px;
    }


    .btn-group .btn {
        border-width: 1px;
        padding: 5px 10px;
    }

    .btn-group .btn:hover {
        transform: translateY(-1px);
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }
</style>